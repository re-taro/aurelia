{
	"name": "visit",
	"version": "3.0.0",
	"type": "module",
	"private": true,
	"engines": {
		"node": "24.11.0"
	},
	"exports": {
		".": {
			"default": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsdown src/index.ts --dts --minify",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint:script": "eslint .",
		"typecheck": "tsc -p . --noEmit"
	},
	"dependencies": {
		"@types/mdast": "catalog:",
		"unist-util-visit": "5.0.0"
	}
}
