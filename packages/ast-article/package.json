{
	"name": "ast-article",
	"version": "3.0.0",
	"type": "module",
	"private": true,
	"engines": {
		"node": "24.11.0"
	},
	"exports": {
		".": {
			"default": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsdown src/index.ts --dts --minify",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint:script": "eslint .",
		"test:unit": "vitest run",
		"typecheck": "tsc -p . --noEmit"
	},
	"dependencies": {
		"ast": "workspace:*",
		"ast-check": "workspace:*",
		"unified": "catalog:"
	},
	"devDependencies": {
		"ast-description-list": "workspace:*",
		"ast-embed": "workspace:*",
		"ast-section": "workspace:*",
		"ast-toc": "workspace:*",
		"ast-transform": "workspace:*",
		"remark-description-list": "workspace:*",
		"remark-embed": "workspace:*",
		"remark-gfm": "4.0.1",
		"remark-parse": "11.0.0"
	}
}
