{
	"name": "ast-transform",
	"version": "3.0.0",
	"type": "module",
	"private": true,
	"exports": {
		".": {
			"default": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsdown src/index.ts --dts --minify",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint:script": "eslint .",
		"typecheck": "tsc -p . --noEmit"
	},
	"dependencies": {
		"@types/mdast": "catalog:",
		"ast": "workspace:*",
		"github-slugger": "2.0.0",
		"remark-check": "workspace:*",
		"ts-pattern": "5.7.1",
		"unified": "catalog:",
		"utils": "workspace:*",
		"visit": "workspace:*"
	}
}
