{
	"name": "remark-check",
	"version": "3.0.0",
	"type": "module",
	"private": true,
	"exports": {
		".": {
			"default": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsc -p . --incremental false",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint:script": "eslint .",
		"typecheck": "tsc -p . --noEmit"
	},
	"dependencies": {
		"@types/mdast": "catalog:"
	}
}
